{
    "name": "humassistant/php-sdk",
    "description": "PHP SDK for the Humassistant API - AI-powered conversational assistants with multi-channel communication",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "humassistant",
        "api",
        "sdk",
        "chatbot",
        "ai",
        "whatsapp"
    ],
    "authors": [
        {
            "name": "Humassistant",
            "email": "info@humassistant.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Humassistant\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Humassistant\\Sdk\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
